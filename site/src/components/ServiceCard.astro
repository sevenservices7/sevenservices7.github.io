---
import { useTranslations, getRoute, type Lang } from '../i18n/ui';
import { money } from '../lib/format';
import type { Service } from '../lib/data';

interface Props { service: Service; lang: Lang; }
const { service, lang } = Astro.props;
const t = useTranslations(lang);

const needsConsult = service.requires_consultation === true || service.action === 'book';
const canAdd = !needsConsult && service.price != null && service.price > 0;
const label = service.price_label || (service.price != null ? money(service.price, lang) : '—');
---
<article class="svc">
  {service.family && <span class="svc-fam">{service.family}</span>}
  <h3 class="svc-name">{service.name}</h3>
  {service.price_obs && <p class="svc-obs">{service.price_obs}</p>}
  {needsConsult && <p class="svc-consult">{t('services.consultNote')}</p>}
  <div class="svc-foot">
    <span class="svc-price">{label}</span>
    {needsConsult ? (
      <a href={getRoute('booking', lang)} class="btn btn-gold btn-sm">{t('nav.booking')}</a>
    ) : canAdd ? (
      <button class="btn btn-gold btn-sm" data-add data-code={service.code} data-pname={service.name} data-price={service.price}>
        {t('common.addToCart')}
      </button>
    ) : null}
  </div>
</article>

<style>
  .svc {
    background: var(--seven-white); border: 1px solid var(--seven-line); border-radius: var(--r-lg);
    padding: 26px; display: flex; flex-direction: column; gap: 10px; height: 100%;
    box-shadow: var(--shadow-sm);
    transition: box-shadow var(--dur-base) var(--ease-out), transform var(--dur-base) var(--ease-out), border-color var(--dur-base) var(--ease-out);
  }
  .svc:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); border-color: var(--g2); }
  .svc-fam {
    align-self: flex-start; font-family: var(--font-head); font-size: .66rem; font-weight: 600;
    letter-spacing: var(--tracking-wider); text-transform: uppercase; color: var(--g0);
  }
  .svc-name { font-family: var(--font-head); font-weight: 500; font-size: 1.15rem; line-height: 1.2; color: var(--seven-navy-deep); }
  .svc-obs { font-size: .8rem; color: var(--seven-muted); line-height: 1.45; margin: 0; }
  .svc-consult { font-size: .78rem; color: var(--g0); line-height: 1.45; margin: 0; padding: 8px 10px; background: rgba(193,154,90,.10); border: 1px solid rgba(193,154,90,.25); border-radius: 8px; }
  .svc-foot { margin-top: auto; padding-top: 12px; display: flex; align-items: center; justify-content: space-between; gap: 10px; }
  .svc-price { font-family: var(--font-head); font-weight: 700; color: var(--seven-navy-deep); font-size: 1.02rem; white-space: nowrap; }
</style>

<script>
  import { addItem } from '../lib/cart';
  document.querySelectorAll('[data-add]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const el = btn as HTMLElement;
      addItem({ service_code: el.dataset.code || '', name: el.dataset.pname || '', price: Number(el.dataset.price || 0) });
      const original = el.textContent;
      el.textContent = '✓';
      setTimeout(() => { el.textContent = original; }, 1100);
    });
  });
</script>
