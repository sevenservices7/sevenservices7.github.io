---
import { useTranslations, getRoute, type Lang } from '../../i18n/ui';
import { getOffices, getServices } from '../../lib/data';
import UnitCard from '../UnitCard.astro';
import ServiceCard from '../ServiceCard.astro';
import TrustBadges from '../TrustBadges.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const offices = await getOffices();
const services = await getServices(6);

const copy = {
  pt: {
    stepsEyebrow: 'Como funciona', stepsTitle: 'Quatro passos, uma equipa.',
    stepsSub: 'Um processo simples e previsível, do primeiro contacto à resolução.',
    steps: [
      ['01', 'Contacto', 'Conte-nos o seu caso. Ouvimos com atenção, sem compromisso.'],
      ['02', 'Diagnóstico', 'Analisamos a documentação e o enquadramento legal. Dizemos o que precisa de facto.'],
      ['03', 'Processo', 'Tratamos de tudo: pedidos, agendamentos, entregas.'],
      ['04', 'Resolução', 'Acompanhamos até ao resultado final.'],
    ],
    statsEyebrow: 'Números',
    stats: [
      'Desde agosto de 2022 no mercado, a crescer todos os anos.',
      '~2000 clientes atendidos — a maioria, clientes fiéis.',
      '4,9 ★ no Google, em 178 avaliações.',
      '3 unidades: Albufeira, Faro e Porto.',
    ],
    statsNote: 'Trabalhamos com os principais organismos: Autoridade Tributária, AIMA, IMT e Segurança Social.',
    testimonials: [
      { q: 'Em três semanas tinha o NIF, a morada fiscal e o pedido de residência submetido. Nunca pensei que pudesse ser tão simples.', who: 'Ana R. · Lisboa' },
      { q: 'O atendimento foi impecável. Resolveram pendências que me diziam serem complicadas, trataram de toda a documentação e deram suporte até à entrevista na AIMA. Confio totalmente na Seven.', who: 'Sara Silva' },
      { q: 'Cheguei em abril como turista. Em outubro tinha o título de residência na mão — fizeram tudo, do NIF ao título.', who: 'Eduardo Rodrigues' },
    ],
  },
  en: {
    stepsEyebrow: 'How it works', stepsTitle: 'Four steps, one team.',
    stepsSub: 'A simple, predictable process, from first contact to resolution.',
    steps: [
      ['01', 'Contact', 'Tell us your case. We listen carefully, with no commitment.'],
      ['02', 'Diagnosis', 'We review your documents and legal situation. We tell you what you actually need.'],
      ['03', 'Process', 'We handle everything: applications, appointments, submissions.'],
      ['04', 'Resolution', 'We follow through to the final result.'],
    ],
    statsEyebrow: 'Numbers',
    stats: [
      'In the market since August 2022, growing every year.',
      '~2000 clients served — most of them loyal clients.',
      '4.9 ★ on Google, across 178 reviews.',
      '3 locations: Albufeira, Faro and Porto.',
    ],
    statsNote: 'We work with the main authorities: Tax Authority, AIMA, IMT and Social Security.',
    testimonials: [
      { q: 'In three weeks I had my NIF, my tax address and my residence application submitted. I never thought it could be so simple.', who: 'Ana R. · Lisbon' },
      { q: 'The service was flawless. They resolved issues others told me were complicated, handled all the paperwork and supported me right up to the AIMA interview. I trust Seven completely.', who: 'Sara Silva' },
      { q: 'I arrived in April as a tourist. By October I had my residence permit in hand — they did everything, from the NIF to the permit.', who: 'Eduardo Rodrigues' },
    ],
  },
  es: {
    stepsEyebrow: 'Cómo funciona', stepsTitle: 'Cuatro pasos, un equipo.',
    stepsSub: 'Un proceso simple y previsible, del primer contacto a la resolución.',
    steps: [
      ['01', 'Contacto', 'Cuéntenos su caso. Escuchamos con atención, sin compromiso.'],
      ['02', 'Diagnóstico', 'Analizamos la documentación y el marco legal. Le decimos lo que realmente necesita.'],
      ['03', 'Proceso', 'Nos ocupamos de todo: solicitudes, citas, entregas.'],
      ['04', 'Resolución', 'Le acompañamos hasta el resultado final.'],
    ],
    statsEyebrow: 'Números',
    stats: [
      'En el mercado desde agosto de 2022, creciendo cada año.',
      '~2000 clientes atendidos — la mayoría, clientes fieles.',
      '4,9 ★ en Google, en 178 reseñas.',
      '3 sedes: Albufeira, Faro y Porto.',
    ],
    statsNote: 'Trabajamos con los principales organismos: Autoridad Tributaria, AIMA, IMT y Seguridad Social.',
    testimonials: [
      { q: 'En tres semanas tenía el NIF, el domicilio fiscal y la solicitud de residencia presentada. Nunca pensé que pudiera ser tan sencillo.', who: 'Ana R. · Lisboa' },
      { q: 'La atención fue impecable. Resolvieron pendientes que me decían que eran complicados, gestionaron toda la documentación y me dieron apoyo hasta la entrevista en AIMA. Confío totalmente en Seven.', who: 'Sara Silva' },
      { q: 'Llegué en abril como turista. En octubre tenía el título de residencia en la mano — hicieron todo, del NIF al título.', who: 'Eduardo Rodrigues' },
    ],
  },
}[lang];
---
<!-- HERO -->
<section class="hero">
  <div class="container hero-in">
    <span class="eyebrow">{t('home.hero.eyebrow')}</span>
    <h1>{t('home.hero.title')} <em>{t('home.hero.titleEm')}</em></h1>
    <p class="hero-lede">{t('home.hero.subtitle')}</p>
    <div class="hero-ctas">
      <button class="btn btn-gold" data-open-attendance>{t('home.hero.ctaPrimary')}</button>
      <a href={getRoute('services', lang)} class="btn btn-light">{t('home.hero.ctaSecondary')}</a>
    </div>
  </div>
  <div class="hero-mark" aria-hidden="true"></div>
</section>

<!-- UNIDADES -->
<section id="unidades" class="bg-off">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">{t('home.units.eyebrow')}</span>
      <h2>{t('home.units.title')}</h2>
      <p class="lead">{t('home.units.subtitle')}</p>
    </div>
    <div class="grid cols-3">
      {offices.map((o) => <UnitCard office={o} lang={lang} />)}
    </div>
    <div class="center" style="margin-top:28px">
      <button class="btn btn-ghost" data-open-attendance>{t('common.onlineService')}</button>
    </div>
  </div>
</section>

<!-- SERVIÇOS -->
<section class="bg-white">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">{t('home.services.eyebrow')}</span>
      <h2>{t('home.services.title')}</h2>
      <p class="lead">{t('home.services.subtitle')}</p>
    </div>
    <div class="grid cols-3">
      {services.map((s) => <ServiceCard service={s} lang={lang} />)}
    </div>
    <div class="center" style="margin-top:32px">
      <a href={getRoute('services', lang)} class="btn btn-ghost">{t('home.services.all')}</a>
    </div>
  </div>
</section>

<!-- COMO FUNCIONA -->
<section class="bg-off">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">{copy.stepsEyebrow}</span>
      <h2>{copy.stepsTitle}</h2>
      <p class="lead">{copy.stepsSub}</p>
    </div>
    <div class="steps">
      {copy.steps.map(([n, ti, d]) => (
        <div class="step"><div class="step-num">{n}</div><h4>{ti}</h4><p>{d}</p></div>
      ))}
    </div>
  </div>
</section>

<!-- NÚMEROS -->
<section class="bg-white">
  <div class="container">
    <div class="section-head center">
      <span class="eyebrow">{copy.statsEyebrow}</span>
    </div>
    <div class="stats">
      {copy.stats.map((s) => <div class="stat">{s}</div>)}
    </div>
    <p class="stats-note center">{copy.statsNote}</p>
  </div>
</section>

<!-- TESTEMUNHOS -->
<section class="testimonial">
  <div class="container">
    <div class="tgrid">
      {copy.testimonials.map((tm) => (
        <figure class="tcard">
          <blockquote>{tm.q}</blockquote>
          <figcaption class="who">{tm.who}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<!-- PARCEIROS -->
<section class="bg-white"><div class="container"><TrustBadges lang={lang} /></div></section>

<!-- CTA -->
<section class="bg-navy cta-band">
  <div class="container center">
    <p class="closing-line">{t('home.closing')}</p>
    <span class="eyebrow">{t('home.cta.title')}</span>
    <h2>{t('home.about.title')}</h2>
    <p class="lead" style="margin-inline:auto">{t('home.cta.body')}</p>
    <a href={getRoute('booking', lang)} class="btn btn-gold" style="margin-top:22px">{t('home.cta.button')}</a>
  </div>
</section>

<style>
  .hero { position: relative; overflow: hidden; background: var(--grad-navy); color: #fff; padding: clamp(72px, 11vw, 120px) 0; }
  .hero-in { position: relative; z-index: 1; }
  .hero h1 { color: #fff; font-size: clamp(2.6rem, 6vw, 4.75rem); line-height: 1.04; letter-spacing: -0.015em; max-width: 14ch; text-wrap: balance; }
  .hero h1 em { font-style: italic; font-weight: 300; color: var(--g1); }
  .hero-lede { color: rgba(255,255,255,.8); max-width: 560px; font-size: clamp(1.05rem, 1.6vw, 1.2rem); margin: 24px 0 36px; line-height: 1.55; }
  .hero-ctas { display: flex; gap: 14px; flex-wrap: wrap; }
  .hero-mark {
    position: absolute; right: -90px; bottom: -90px; width: min(620px, 70vw); height: min(620px, 70vw);
    background: url('/brand/logo_isotype_white_gold.png') center/contain no-repeat; opacity: .2;
    pointer-events: none; filter: drop-shadow(0 20px 60px rgba(0,0,0,.35));
  }

  .steps { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .step { padding-top: 56px; position: relative; }
  .step-num { position: absolute; top: 0; left: 0; font-family: var(--font-head); font-weight: 300; font-style: italic; font-size: 3.6rem; line-height: 1; color: var(--g2); opacity: .9; }
  .step h4 { font-weight: 600; text-transform: uppercase; letter-spacing: var(--tracking-wide); font-size: .9rem; margin-bottom: 8px; }
  .step p { color: var(--seven-muted); font-size: .92rem; line-height: 1.55; }

  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 18px; }
  .stat {
    background: var(--seven-white); border: 1px solid var(--seven-line); border-left: 3px solid var(--g1);
    border-radius: var(--r-lg); padding: 22px 24px; box-shadow: var(--shadow-sm);
    font-family: var(--font-head); font-weight: 500; font-size: 1.02rem; line-height: 1.35; color: var(--seven-navy-deep);
  }
  .stats-note { margin-top: 22px; color: var(--seven-muted); font-size: .92rem; }

  .testimonial { background: var(--seven-navy-deep); color: #fff; padding: clamp(64px, 9vw, 104px) 0; }
  .tgrid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .tcard { margin: 0; display: flex; flex-direction: column; gap: 18px; padding: 28px; background: rgba(255,255,255,.04); border: 1px solid rgba(255,255,255,.12); border-radius: var(--r-lg); }
  .tcard blockquote { font-family: var(--font-head); font-weight: 300; font-style: italic; font-size: 1.12rem; line-height: 1.45; margin: 0; color: #fff; }
  .tcard blockquote::before { content: '“'; color: var(--g1); }
  .tcard blockquote::after { content: '”'; color: var(--g1); }
  .tcard .who { margin-top: auto; font-family: var(--font-head); font-weight: 500; font-size: .74rem; text-transform: uppercase; letter-spacing: var(--tracking-widest); color: var(--g1); }

  .cta-band { padding-block: clamp(56px, 8vw, 90px); }
  .closing-line { font-family: var(--font-head); font-weight: 300; font-style: italic; font-size: clamp(1.4rem, 3vw, 2.1rem); color: var(--g1); margin-bottom: 22px; }

  @media (max-width: 860px) { .steps { grid-template-columns: 1fr 1fr; gap: 32px; } .stats { grid-template-columns: 1fr 1fr; } .tgrid { grid-template-columns: 1fr; } }
  @media (max-width: 480px) { .steps { grid-template-columns: 1fr; } .stats { grid-template-columns: 1fr; } }
</style>
