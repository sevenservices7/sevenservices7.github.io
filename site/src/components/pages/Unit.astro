---
import { useTranslations, getRoute, type Lang } from '../../i18n/ui';
import { dateLong, mapEmbed, mapsLink, initials } from '../../lib/format';
import { getTeam, type Office } from '../../lib/data';
import WhatsAppButton from '../WhatsAppButton.astro';

interface Props { office: Office; lang: Lang; }
const { office, lang } = Astro.props;
const t = useTranslations(lang);
const team = await getTeam();
const coordinator = team.find((m) => m.code && m.code === office.coordinator_code);
const coordName = office.coordinator_name || coordinator?.name || '';
const coordRole = office.coordinator_role || coordinator?.role_label || '';
const coordPhoto = coordinator?.photo_url || '';
const waText =
  lang === 'en'
    ? `Hello! I'd like information from the ${office.name} unit.`
    : lang === 'es'
      ? `¡Hola! Quisiera información de la sede ${office.name}.`
      : `Olá! Gostaria de informações da unidade ${office.name}.`;
---
<section class="bg-navy">
  <div class="container unit-hero">
    <div>
      <a href={`${getRoute('home', lang)}#unidades`} class="unit-back">← {t('nav.units')}</a>
      <h1>{office.name}</h1>
      {office.is_open ? (
        <span class="badge badge-open">{t('common.open')}</span>
      ) : (
        <span class="badge badge-soon">{t('common.soon')}</span>
      )}
      <p class="lead" style="margin-top:14px">{office.address}</p>
      {office.is_open && office.opening_date && (
        <p style="color:rgba(255,255,255,.7)">{t('common.openedOn')} {dateLong(office.opening_date, lang)}</p>
      )}
      <div class="unit-hero-cta">
        {office.is_open && <WhatsAppButton whatsapp={office.whatsapp} text={waText} label={t('common.whatsapp')} />}
        <a href={mapsLink(office)} target="_blank" rel="noopener" class="btn btn-light">{t('common.maps')}</a>
      </div>
    </div>
  </div>
</section>

<section>
  <div class="container unit-body">
    <div class="unit-info">
      {coordName && (
        <div class="coord card">
          <div class="coord-photo">
            {coordPhoto ? <img src={coordPhoto} alt={coordName} /> : <span>{initials(coordName)}</span>}
          </div>
          <div>
            <h3 style="margin:0">{coordName}</h3>
            <p class="muted" style="margin:0">{coordRole}</p>
          </div>
        </div>
      )}
      {office.hours && Object.keys(office.hours).length > 0 && (
        <div class="card" style="padding:20px;margin-top:18px">
          <h3 style="margin:0 0 8px">{lang === 'en' ? 'Hours' : lang === 'es' ? 'Horario' : 'Horário'}</h3>
          {Object.entries(office.hours).map(([k, v]) => <p style="margin:2px 0"><strong>{k}:</strong> {v}</p>)}
        </div>
      )}
      <a href={getRoute('booking', lang)} class="btn btn-gold btn-block" style="margin-top:18px">{t('nav.booking')}</a>
    </div>

    <div class="unit-map">
      <iframe
        title={`Mapa — ${office.name}`}
        src={mapEmbed(office)}
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        allowfullscreen
      ></iframe>
    </div>
  </div>
</section>

<style>
  .unit-hero { padding-block: clamp(40px, 7vw, 90px); }
  .unit-back { color: var(--g1); font-size: .9rem; display: inline-block; margin-bottom: 14px; }
  .unit-hero h1 { display: inline-block; margin-right: 12px; }
  .unit-hero-cta { display: flex; gap: 12px; flex-wrap: wrap; margin-top: 24px; }
  .unit-body { display: grid; grid-template-columns: 360px 1fr; gap: 32px; align-items: start; }
  .coord { display: flex; align-items: center; gap: 14px; padding: 18px; }
  .coord-photo {
    width: 64px; height: 64px; border-radius: 50%; overflow: hidden; flex-shrink: 0;
    background: var(--grad-navy); display: flex; align-items: center; justify-content: center;
    color: var(--g1); font-family: var(--font-head); font-weight: 700; border: 2px solid var(--g3);
  }
  .coord-photo img { width: 100%; height: 100%; object-fit: cover; }
  .unit-map iframe { width: 100%; min-height: 420px; border: 0; border-radius: var(--r-lg); box-shadow: var(--shadow-md); }
  @media (max-width: 820px) { .unit-body { grid-template-columns: 1fr; } }
</style>
