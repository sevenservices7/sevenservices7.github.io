---
import { useTranslations, getRoute, type Lang } from '../../i18n/ui';
import { getServices, type Service } from '../../lib/data';
import { localName, familyLabel } from '../../lib/format';
import ServiceCard from '../ServiceCard.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const services = await getServices();
const L = (pt: string, en: string, es: string) => (lang === 'en' ? en : lang === 'es' ? es : pt);

// ---- Catálogo completo: agrupa por família, na ordem da marca ----
const familyOrder = ['AIMA', 'A.T - Finanças', 'Docs. Brasil', 'IMT', 'Segurança Social', 'Juridico', 'Contabilidade', 'Outros'];
const byFamily = new Map<string, Service[]>();
for (const s of services) {
  const key = s.family || 'Outros';
  if (!byFamily.has(key)) byFamily.set(key, []);
  byFamily.get(key)!.push(s);
}
const orderedKeys = [
  ...familyOrder.filter((f) => byFamily.has(f)),
  ...[...byFamily.keys()].filter((f) => !familyOrder.includes(f)),
];
const groups = orderedKeys.map((f) => [f, byFamily.get(f)!] as [string, Service[]]);

// ---- Destaques (lista plana, compacta) ----
const byCode = new Map(services.map((s) => [s.code, s]));
const get = (code: string) => byCode.get(code);
const nac: Service = {
  code: 'JR375-nac', name: L('Nacionalidade Portuguesa', 'Portuguese Citizenship', 'Nacionalidad Portuguesa'),
  category: '', family: 'Juridico', price: 550, price_label: 'a partir de 550 €',
  requires_consultation: true, action: 'book',
  price_obs: L('Taxa de 250 € não inclusa', '€250 government fee not included', 'Tasa de 250 € no incluida'),
};

type Feat =
  | { t: 'c'; code: string }
  | { t: 'b'; service: Service }
  | { t: 'g'; title: string; subtitle: string; label: string; book: boolean; variants: string[] };

const featured: Feat[] = [
  { t: 'c', code: 'AM152' },
  { t: 'c', code: 'AM156' },
  { t: 'g', title: L('Renovação de Residência', 'Residence Permit Renewal', 'Renovación de Residencia'),
    subtitle: L('Títulos caducados até 30/06/2025 · após 30/06/2025 · Menores · CPLP · Longa duração',
                'Permits expired until 30/06/2025 · after 30/06/2025 · Minors · CPLP · Long-term',
                'Títulos caducados hasta 30/06/2025 · tras 30/06/2025 · Menores · CPLP · Larga duración'),
    label: 'a partir de 100 €', book: false, variants: ['AM160', 'AM157', 'AM161', 'AM162', 'AM163'] },
  { t: 'c', code: 'AM165' },
  { t: 'c', code: 'AM167' },
  { t: 'c', code: 'AT109' },
  { t: 'c', code: 'AT103' },
  { t: 'c', code: 'AT106' },
  { t: 'c', code: 'AT112' },
  { t: 'c', code: 'BR269' },
  { t: 'c', code: 'BR255' },
  { t: 'c', code: 'BR259' },
  { t: 'c', code: 'BR268' },
  { t: 'c', code: 'IM307' },
  { t: 'c', code: 'SS404' },
  { t: 'c', code: 'SS408' },
  { t: 'c', code: 'JR387' },
  { t: 'g', title: L('Ações Judiciais', 'Lawsuits', 'Acciones Judiciales'),
    subtitle: L('Atraso na emissão de A.R · Indeferimento · Renovação · Reagrupamento familiar · Nacionalidade · CPLP · Estudante · Manifestação de Interesse · Visto sem agendamento',
                'Residence permit delay · Refusal · Renewal · Family reunification · Citizenship · CPLP · Student · Expression of interest · Visa without appointment',
                'Retraso en residencia · Denegación · Renovación · Reagrupación familiar · Nacionalidad · CPLP · Estudiante · Manifestación de interés · Visado sin cita'),
    label: 'a partir de 700 €', book: true, variants: ['JR350', 'JR353', 'JR357', 'JR356', 'JR355', 'JR351', 'JR352', 'JR354', 'JR358'] },
  { t: 'b', service: nac },
];
---
<section class="bg-navy center">
  <div class="container" style="max-width:720px">
    <span class="eyebrow">{t('home.services.eyebrow')}</span>
    <h1>{t('home.services.title')}</h1>
    <p class="lead" style="margin-inline:auto">{t('home.services.subtitle')}</p>
  </div>
</section>

<!-- DESTAQUES (compacto, sem separação por família) -->
<section class="bg-off">
  <div class="container">
    <div class="section-head center"><span class="eyebrow">{t('home.services.eyebrow')}</span><h2>{t('services.featuredTitle')}</h2></div>
    <div class="featured-grid">
      {featured.map((it) => (
        it.t === 'c' ? (
          get(it.code) ? <ServiceCard service={get(it.code)!} lang={lang} compact /> : null
        ) : it.t === 'b' ? (
          <ServiceCard service={it.service} lang={lang} compact />
        ) : (
          <details class="fgroup">
            <summary class="fgroup-sum">
              <div class="fgroup-main">
                <h4 class="fgroup-title">{it.title}</h4>
                <p class="fgroup-sub">{it.subtitle}</p>
              </div>
              <div class="fgroup-foot">
                <span class="svc-price">{it.label}</span>
                <span class="btn btn-gold btn-sm">{it.book ? t('nav.booking') : t('services.seeOptions')}</span>
              </div>
            </summary>
            <div class="fgroup-variants">
              <div class="featured-grid">
                {it.variants.map((code) => (get(code) ? <ServiceCard service={get(code)!} lang={lang} compact /> : null))}
              </div>
            </div>
          </details>
        )
      ))}
    </div>
  </div>
</section>

<!-- CATÁLOGO COMPLETO -->
<section>
  <div class="container">
    <div class="section-head center"><h2>{t('services.allTitle')}</h2></div>
    <div class="cat-filters">
      <input id="svc-search" type="search" class="cat-search" placeholder={t('services.search')} aria-label={t('services.search')} />
      <div class="cat-chips">
        <button class="chip is-active" data-fam="all">{t('services.filterAll')}</button>
        {groups.map(([family]) => <button class="chip" data-fam={family}>{familyLabel(family, lang)}</button>)}
      </div>
    </div>
    <div class="cat-groups">
      {groups.map(([family, items]) => (
        <div class="cat-group" data-fam-group={family}>
          <h3 class="svc-group-title">{familyLabel(family, lang)}</h3>
          <div class="grid cols-3">
            {items.map((s) => (
              <div class="svc-wrap" data-fam={family} data-name={localName(s, lang).toLowerCase()}>
                <ServiceCard service={s} lang={lang} />
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
    <div class="center" style="margin-top:36px">
      <a href={getRoute('cart', lang)} class="btn btn-gold">{t('common.cart')}</a>
    </div>
  </div>
</section>

<style>
  .featured-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(216px, 1fr)); gap: 14px; align-items: stretch; }
  .fgroup { grid-column: 1 / -1; background: var(--seven-white); border: 1px solid var(--seven-line); border-left: 3px solid var(--g1); border-radius: 12px; box-shadow: var(--shadow-sm); }
  .fgroup-sum { list-style: none; cursor: pointer; display: flex; align-items: center; justify-content: space-between; gap: 18px; padding: 16px 20px; }
  .fgroup-sum::-webkit-details-marker { display: none; }
  .fgroup-main { display: flex; flex-direction: column; gap: 3px; }
  .fgroup-title { font-family: var(--font-head); font-weight: 600; font-size: 1.08rem; color: var(--seven-navy-deep); margin: 0; }
  .fgroup-sub { color: var(--seven-muted); font-size: .78rem; line-height: 1.45; margin: 0; max-width: 70ch; }
  .fgroup-foot { display: flex; align-items: center; gap: 14px; flex: none; }
  .fgroup-variants { padding: 0 20px 20px; }

  .cat-filters { display: flex; flex-wrap: wrap; gap: 16px; align-items: center; justify-content: space-between; margin-bottom: 28px; }
  .cat-search { flex: 1 1 260px; max-width: 360px; padding: 11px 16px; border: 1px solid var(--seven-line); border-radius: 999px; font: inherit; background: var(--seven-white); }
  .cat-chips { display: flex; flex-wrap: wrap; gap: 8px; }
  .chip { font-family: var(--font-head); font-size: .8rem; font-weight: 500; padding: 7px 14px; border-radius: 999px; border: 1px solid var(--seven-line); background: var(--seven-white); color: var(--seven-navy-deep); cursor: pointer; transition: all var(--dur-fast) var(--ease-out); }
  .chip:hover { border-color: var(--g2); }
  .chip.is-active { background: var(--seven-navy-deep); color: #fff; border-color: var(--seven-navy-deep); }

  .cat-group { margin-bottom: clamp(32px, 5vw, 52px); }
  .svc-group-title { font-size: 1.1rem; color: var(--g0); margin-bottom: 18px; padding-bottom: 8px; border-bottom: 2px solid var(--g3); }
  .svc-wrap { display: flex; }
  .svc-wrap > :global(.svc) { width: 100%; }

  @media (max-width: 640px) { .fgroup-sum { flex-direction: column; align-items: flex-start; gap: 12px; } }
</style>

<script>
  const search = document.getElementById('svc-search') as HTMLInputElement | null;
  const chips = Array.from(document.querySelectorAll<HTMLButtonElement>('.cat-chips .chip'));
  const wraps = Array.from(document.querySelectorAll<HTMLElement>('.svc-wrap'));
  const groups = Array.from(document.querySelectorAll<HTMLElement>('.cat-group'));
  let fam = 'all';
  let q = '';
  function apply() {
    wraps.forEach((w) => {
      const okFam = fam === 'all' || w.dataset.fam === fam;
      const okQ = !q || (w.dataset.name || '').includes(q);
      w.style.display = okFam && okQ ? '' : 'none';
    });
    groups.forEach((g) => {
      const any = Array.from(g.querySelectorAll<HTMLElement>('.svc-wrap')).some((w) => w.style.display !== 'none');
      g.style.display = any ? '' : 'none';
    });
  }
  chips.forEach((c) => c.addEventListener('click', () => {
    chips.forEach((x) => x.classList.remove('is-active'));
    c.classList.add('is-active');
    fam = c.dataset.fam || 'all';
    apply();
  }));
  search?.addEventListener('input', () => { q = (search.value || '').trim().toLowerCase(); apply(); });
</script>
