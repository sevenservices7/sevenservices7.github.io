---
import { useTranslations, type Lang } from '../i18n/ui';
import { getOffices } from '../lib/data';
import UnitCard from './UnitCard.astro';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const offices = await getOffices();
---
<div class="ovl" data-overlay hidden role="dialog" aria-modal="true" aria-labelledby="ovl-title">
  <div class="ovl-panel" role="document">
    <button class="ovl-x" data-close aria-label="Fechar">&times;</button>

    <div class="ovl-head">
      <img src="/assets/logos/seven-icon.png" alt="" height="44" class="ovl-icon" />
      <span class="eyebrow">{t('overlay.eyebrow')}</span>
      <h2 id="ovl-title">{t('overlay.title')}</h2>
      <p class="lead">{t('overlay.subtitle')}</p>
    </div>

    <div class="ovl-grid">
      {offices.map((o) => <UnitCard office={o} lang={lang} compact />)}
    </div>

    <div class="ovl-foot">
      <button class="btn btn-gold" data-open-attendance>{t('common.onlineService')}</button>
      <button class="btn btn-ghost" data-close>{t('common.enterSite')}</button>
    </div>
  </div>
</div>

<style>
  .ovl {
    position: fixed; inset: 0; z-index: 200;
    background: rgba(7,20,50,.62); backdrop-filter: blur(6px);
    display: flex; align-items: center; justify-content: center;
    padding: clamp(12px, 4vw, 40px); overflow-y: auto;
  }
  .ovl[hidden] { display: none; }
  .ovl-panel {
    position: relative; width: 100%; max-width: 1040px;
    background: var(--off); border-radius: var(--r-2xl);
    box-shadow: var(--shadow-xl); padding: clamp(24px, 4vw, 48px);
    animation: ovl-in .25s ease;
  }
  @keyframes ovl-in { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: none; } }
  .ovl-x {
    position: absolute; top: 14px; right: 18px; background: none; border: 0;
    font-size: 2rem; line-height: 1; color: var(--t3); cursor: pointer;
  }
  .ovl-x:hover { color: var(--n1); }
  .ovl-head { text-align: center; max-width: 640px; margin: 0 auto clamp(20px, 3vw, 32px); }
  .ovl-icon { margin: 0 auto 14px; }
  .ovl-head h2 { margin-bottom: 10px; }
  .ovl-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 18px; }
  .ovl-foot { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; margin-top: clamp(20px, 3vw, 32px); }
  @media (max-width: 820px) { .ovl-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const KEY = 'seven_overlay_seen';
  const overlay = document.querySelector('[data-overlay]') as HTMLElement | null;

  function close() {
    overlay?.setAttribute('hidden', '');
    document.body.style.overflow = '';
    try { localStorage.setItem(KEY, '1'); } catch {}
  }
  function open() {
    overlay?.removeAttribute('hidden');
    document.body.style.overflow = 'hidden';
    (overlay?.querySelector('[data-close]') as HTMLElement | null)?.focus();
  }

  if (overlay) {
    let seen = false;
    try { seen = localStorage.getItem(KEY) === '1'; } catch {}
    if (!seen) open();

    // Fechar ao clicar fora do painel
    overlay.addEventListener('click', (e) => { if (e.target === overlay) close(); });
    overlay.querySelectorAll('[data-close]').forEach((b) => b.addEventListener('click', close));
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !overlay.hasAttribute('hidden')) close();
    });
    overlay.querySelectorAll('[data-open-attendance]').forEach((b) =>
      b.addEventListener('click', () => {
        close();
        window.dispatchEvent(new CustomEvent('seven:open-attendance'));
      })
    );

    // Permite reabrir o overlay a partir de qualquer link [data-units-overlay]
    document.querySelectorAll('[data-units-overlay]').forEach((el) =>
      el.addEventListener('click', (e) => { e.preventDefault(); open(); })
    );
  }
</script>
