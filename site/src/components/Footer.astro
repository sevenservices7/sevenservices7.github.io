---
import { useTranslations, getRoute, type Lang } from '../i18n/ui';
import { getOffices } from '../lib/data';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
const offices = await getOffices();
const year = new Date().getFullYear();

function unitHref(slug: string) {
  if (lang === 'en') return `/en/units/${slug}`;
  if (lang === 'es') return `/es/unidades/${slug}`;
  return `/unidades/${slug}`;
}
---
<footer class="footer">
  <div class="container">
    <div class="footer-grid">
      <div class="footer-brand">
        <img src="/brand/logo_primary_white_gold.png" alt="Seven Services" />
        <p class="footer-slogan">{t('brand.slogan')}</p>
        <p>{t('footer.tagline')}</p>
        <p class="footer-legal">{t('footer.legalEntity')}</p>
      </div>

      <div class="footer-col">
        <h5>{t('footer.company')}</h5>
        <ul>
          <li><a href={getRoute('about', lang)}>{t('nav.about')}</a></li>
          <li><a href={getRoute('team', lang)}>{t('nav.team')}</a></li>
          <li><a href={getRoute('services', lang)}>{t('nav.services')}</a></li>
          <li><a href={getRoute('booking', lang)}>{t('nav.booking')}</a></li>
        </ul>
      </div>

      <div class="footer-col">
        <h5>{t('footer.units')}</h5>
        <ul>
          {offices.map((o) => <li><a href={unitHref(o.slug)}>{o.name}</a></li>)}
        </ul>
      </div>

      <div class="footer-col">
        <h5>{t('footer.links')}</h5>
        <ul>
          <li><a href={getRoute('contact', lang)}>{t('nav.contact')}</a></li>
          <li><a href={getRoute('terms', lang)}>{t('footer.terms')}</a></li>
          <li><a href={getRoute('privacy', lang)}>{t('footer.privacy')}</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-fine">
      <span>© {year} Seven Services · {t('site.tagline')}</span>
      <span>NIPC 518 146 529</span>
    </div>
  </div>
</footer>

<style>
  .footer { background: var(--seven-navy-deep); color: var(--seven-bone); padding: clamp(48px, 7vw, 64px) 0 32px; }
  .footer-grid { display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 40px; margin-bottom: 48px; }
  .footer-brand img { height: 46px; width: auto; margin-bottom: 14px; }
  .footer-slogan { font-family: var(--font-head); font-style: italic; font-weight: 300; color: var(--g1) !important; font-size: 1.02rem !important; max-width: none !important; margin-bottom: 12px; }
  .footer-brand p { color: rgba(255,255,255,.6); font-size: .9rem; max-width: 30ch; line-height: 1.6; }
  .footer-legal { margin-top: 12px; font-size: .8rem; color: rgba(255,255,255,.45) !important; }
  .footer-col h5 { font-family: var(--font-head); font-weight: 500; font-size: .72rem; text-transform: uppercase; letter-spacing: var(--tracking-widest); color: var(--g1); margin-bottom: 16px; }
  .footer-col ul { list-style: none; display: flex; flex-direction: column; gap: 10px; }
  .footer-col a { color: rgba(255,255,255,.78); font-size: .92rem; transition: color var(--dur-fast) var(--ease-out); }
  .footer-col a:hover { color: var(--g1); }
  .footer-fine { display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; padding-top: 24px; border-top: 1px solid rgba(255,255,255,.08); font-size: .8rem; color: rgba(255,255,255,.4); }
  @media (max-width: 820px) { .footer-grid { grid-template-columns: 1fr 1fr; gap: 32px; } }
  @media (max-width: 520px) { .footer-grid { grid-template-columns: 1fr; } }
</style>
